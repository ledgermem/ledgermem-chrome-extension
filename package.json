{
  "name": "@getmnemo/chrome-extension",
  "version": "0.1.0",
  "description": "Mnemo cross-browser MV3 extension — capture pages, selections, YouTube transcripts, Twitter threads, Reddit posts.",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@getmnemo/memory": "^0.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/node": "^22.7.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^15.7.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1",
    "wxt": "^0.19.13"
  },
  "license": "MIT"
}
